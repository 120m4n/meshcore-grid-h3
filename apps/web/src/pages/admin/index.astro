---
import '../../styles/global.css';
---
<html lang="es">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><link rel="icon" type="image/svg+xml" href="/favicon.svg" /><title>Moderación — MeshCore Santander</title></head>
<body>
  <header class="topbar">
    <h1 class="brand">
      <svg class="brand-bars" viewBox="0 0 18 14" aria-hidden="true">
        <rect x="0" y="8" width="3" height="6" rx="1" />
        <rect x="5" y="5" width="3" height="9" rx="1" />
        <rect x="10" y="2" width="3" height="12" rx="1" />
        <rect x="15" y="0" width="3" height="14" rx="1" />
      </svg>
      Moderación
    </h1>
    <nav><a href="/">Volver al mapa</a></nav>
  </header>

  <main>
    <h2 class="section-title">Reportes pendientes</h2>
    <div class="table-scroll">
      <table id="reports-table">
        <thead>
          <tr>
            <th>Celda H3</th><th>Quién reporta</th><th>Calidad</th>
            <th>Mensaje</th><th>Fecha</th><th>Acciones</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
    <p id="status" class="hint"></p>

    <h2 class="section-title">Celdas activas</h2>
    <label>Filtrar por plus code
      <input type="text" id="cells-filter" placeholder="p.ej. 869876XV+GX" autocomplete="off" />
    </label>
    <div class="table-scroll">
      <table id="cells-table">
        <thead>
          <tr>
            <th class="sortable" data-sort="h3_index">Celda H3 <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="plus_code">Plus code <span class="sort-indicator"></span></th>
            <th class="sortable" data-sort="score_pct">Señal <span class="sort-indicator"></span></th>
            <th>Reportes</th>
            <th class="sortable" data-sort="last_report_at">Última actualización <span class="sort-indicator"></span></th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
    <p id="cells-status" class="hint"></p>
    <div class="table-actions">
      <button id="cells-prev" class="btn-secondary btn-sm">Anterior</button>
      <span id="cells-page-indicator" class="hint"></span>
      <button id="cells-next" class="btn-secondary btn-sm">Siguiente</button>
    </div>

    <h2 class="section-title">Códigos de invitación</h2>
    <button id="btn-generate-invite" class="btn-secondary">Generar código</button>
    <div class="table-scroll">
      <table id="invite-codes-table">
        <thead>
          <tr>
            <th>Código</th><th>Estado</th><th>Creado</th><th>Expira / usado</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
    <p id="invite-codes-status" class="hint"></p>
  </main>

  <script src="../../lib/adminPage.ts"></script>
</body>
</html>
