---
import '../styles/global.css';
---
<html lang="es">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><link rel="icon" type="image/svg+xml" href="/favicon.svg" /><title>Ingresar — MeshCore Santander</title></head>
<body>
  <header class="topbar">
    <h1 class="brand">
      <svg class="brand-bars" viewBox="0 0 18 14" aria-hidden="true">
        <rect x="0" y="8" width="3" height="6" rx="1" />
        <rect x="5" y="5" width="3" height="9" rx="1" />
        <rect x="10" y="2" width="3" height="12" rx="1" />
        <rect x="15" y="0" width="3" height="14" rx="1" />
      </svg>
      Ingresar
    </h1>
    <nav><a href="/">Volver al mapa</a></nav>
  </header>

  <main class="form-container">
    <form id="login-form">
      <label>Email <input type="email" id="email" required /></label>
      <label>Contraseña <input type="password" id="password" required /></label>
      <button type="submit">Ingresar</button>
    </form>
    <p>¿No tienes cuenta? <a href="/register">Regístrate</a></p>
  </main>

  <script src="../lib/loginPage.ts"></script>
</body>
</html>
