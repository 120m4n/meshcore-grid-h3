---
import 'leaflet/dist/leaflet.css';
import '../styles/global.css';
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Mapa de disponibilidad MeshCore — Santander</title>
</head>
<body>
  <header class="topbar">
    <h1 class="brand">
      <svg class="brand-bars" viewBox="0 0 18 14" aria-hidden="true">
        <rect x="0" y="8" width="3" height="6" rx="1" />
        <rect x="5" y="5" width="3" height="9" rx="1" />
        <rect x="10" y="2" width="3" height="12" rx="1" />
        <rect x="15" y="0" width="3" height="14" rx="1" />
      </svg>
      MeshCore Santander
    </h1>
    <nav>
      <a href="/reportar" class="btn-primary" id="nav-report" hidden>Reportar conectividad</a>
      <a href="/admin" id="nav-admin" hidden>Admin</a>
      <button id="btn-enable-test" hidden>Activar modo prueba</button>
      <button id="btn-clear-test" hidden>Limpiar pruebas</button>
      <a href="/login" id="nav-login">Ingresar</a>
    </nav>
  </header>

  <div id="map"></div>

  <div class="legend">
    <div class="legend-title">Cobertura de señal</div>
    <div class="legend-row"><span class="legend-swatch" style="background:#2ecc71"></span>Excelente</div>
    <div class="legend-row"><span class="legend-swatch" style="background:#f1c40f"></span>Buena</div>
    <div class="legend-row"><span class="legend-swatch" style="background:#e74c3c"></span>Pobre</div>
  </div>

  <div class="brand-overlay" aria-hidden="true">
    <svg class="brand-overlay-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="19" r="1.5" fill="currentColor" />
      <path d="M8 15.5a5.5 5.5 0 0 1 8 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      <path d="M5 12a10 10 0 0 1 14 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" opacity="0.75" />
      <path d="M2 8.5a15 15 0 0 1 20 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" opacity="0.5" />
    </svg>
    <span class="brand-overlay-text"><strong>Mesh</strong>Core</span>
  </div>

  <script src="../lib/mapPage.ts"></script>
</body>
</html>
