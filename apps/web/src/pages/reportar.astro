---
import 'leaflet/dist/leaflet.css';
import '../styles/global.css';
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Reportar conectividad — MeshCore Santander</title>
</head>
<body>
  <header class="topbar">
    <h1>Reportar conectividad</h1>
    <nav><a href="/">Volver al mapa</a></nav>
  </header>

  <main class="form-container">
    <form id="report-form">
      <fieldset>
        <legend>Ubicación</legend>
        <div class="radio-group">
          <label class="radio-option">
            <input type="radio" name="input_method" value="coords" checked />
            <span>Coordenadas GPS</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="input_method" value="pluscode" />
            <span>Plus Code</span>
          </label>
          <label class="radio-option">
            <input type="radio" name="input_method" value="mapclick" />
            <span>Clic en el mapa</span>
          </label>
        </div>

        <div id="coords-fields">
          <label>Latitud <input type="number" step="any" id="lat" placeholder="7.1193" /></label>
          <label>Longitud <input type="number" step="any" id="lon" placeholder="-73.1227" /></label>
          <button type="button" id="btn-geo" class="btn-secondary">Usar mi ubicación</button>
        </div>

        <div id="pluscode-fields" hidden>
          <label>Plus Code <input type="text" id="plus_code" placeholder="p.ej. 869876XV+GX" /></label>
        </div>

        <div id="mapclick-fields" hidden>
          <div id="map-picker"></div>
          <p id="picker-confirm" class="hint">Hacé clic en el mapa para elegir la ubicación.</p>
        </div>
      </fieldset>

      <fieldset>
        <legend>Identificación</legend>
        <label>¿Quién reporta? (opcional)
          <input type="text" id="reporter_display_name" placeholder="Anónimo" maxlength="60" />
        </label>
        <p class="hint">Solo lo verá el administrador al revisar tu reporte.</p>
      </fieldset>

      <fieldset>
        <legend>Reporte</legend>
        <label>Calidad de señal
          <select id="signal_quality" required>
            <option value="sin_cobertura">Sin cobertura</option>
            <option value="debil">Débil</option>
            <option value="buena">Buena</option>
            <option value="excelente">Excelente</option>
          </select>
        </label>
        <label>Observación (opcional)
          <textarea id="message" rows="3" maxlength="120" placeholder="Detalles adicionales..."></textarea>
        </label>
        <p id="message-count" class="hint">0/120</p>
      </fieldset>

      <p class="hint">Queda <strong>pendiente de aprobación</strong> antes de verse en el mapa.</p>

      <button type="submit">Enviar reporte</button>
    </form>
  </main>

  <script src="../lib/reportPage.ts"></script>
</body>
</html>
