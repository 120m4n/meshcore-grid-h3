JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
H3_RESOLUTION=8
# Dominio real del frontend — el backend lo usa para restringir CORS.
# Debe coincidir con el PUBLIC_API_URL horneado en la imagen web por
# infra/deploy.sh (mismo origen: nginx en el contenedor web proxea
# /api/ al contenedor api, el navegador nunca ve un host distinto).
WEB_ORIGIN=https://meshcore.example.com

# Imagen a pullear desde GHCR — deploy.sh imprime el owner/tag exactos
# al terminar.
IMAGE_OWNER=120m4n
IMAGE_TAG=latest

# Puerto publicado en el host para pruebas locales de las imágenes
# pulleadas, antes de que Traefik quede al frente (sin labels todavía).
WEB_PORT=8081
